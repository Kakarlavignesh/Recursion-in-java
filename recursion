fibonacci using dp ....

import java.util.*;
class Main {
    public static void fibonacci(int n){
        if(n==0){
            return;
        }
        if(n==1 || n==2){
            System.out.println(1);
        }
        int[] dp=new int[n+1];
        dp[1]=1;
        dp[2]=1;
        for(int i=3;i<=n;i++){
            dp[i]=dp[i-1]+dp[i-2];
        }
        for(int i=1;i<=n;i++){
            System.out.println(dp[i]+" ");
        }
    }
    public static void main(String[] args) {
        fibonacci(5);
    }
}

